n:
  schedule:
    - cron: '30 3 * * *'
  workflow_dispatch:

permissions:
  contents: write
  actions: write

jobs:
  auto-commit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          token: \${{ secrets.AUTO_COMMIT_PAT }}
          ref: main

      - name: Configure Git
        run: |
          git config user.email "auto-commit@scheduler.local"
          git config user.name "CommitPilot"

      - name: Commit daily log
        run: |
          MSGS=("Daily log update" "Keeping streak alive" "Automated daily commit" "Consistency is key" "Another day another commit" "Streak maintained" "chore: daily automated maintenance" "Focused. Committed. Daily.")
          MSG="\${MSGS[$RANDOM % \${#MSGS[@]}]}"
          TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
          FILE=daily-log.json

          if [ -f "$FILE" ]; then
            python3 -c "
import json, os
try:
    d = json.load(open('$FILE'))
except:
    d = {}
if not isinstance(d.get('entries'), list):
    d['entries'] = []
d['entries'].append({'timestamp': '$TIMESTAMP', 'message': '$MSG', 'automated': True})
d['entries'] = d['entries'][-365:]
with open('$FILE', 'w') as f:
    json.dump(d, f, indent=2)
    f.write('\\n')
"
          else
            echo '{"entries":[{"timestamp":"'"$TIMESTAMP"'","message":"'"$MSG"'","automated":true}]}' > "$FILE"
          fi

          git add "$FILE"
          git diff --staged --quiet || (git commit -m "$MSG" && git push origin main)
`;

async function main() {
  const octokit = new Octokit({ auth: TOKEN });
  let sha;
  try {
    const { data } = await octokit.rest.repos.getContent({ owner: OWNER, repo: REPO, path: PATH });
    sha = data.sha;
  } catch (e) {
    if (e.status !== 404) throw e;
  }

  try {
    await octokit.rest.repos.createOrUpdateFileContents({
      owner: OWNER,
      repo: REPO,
      path: PATH,
      message: "fix: update workflow file",
      content: Buffer.from(YAML).toString("base64"),
      sha: sha
    });
    console.log("Successfully pushed updated workflow!");
  } catch (e) {
    console.error("Error pushing file:", e.message);
  }
}
main();
